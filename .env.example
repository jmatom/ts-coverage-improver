# Top-level .env loaded by `docker compose`. Copy to `.env` and fill in.
# Local-dev (no docker) uses backend/.env.example with the same keys.

# === Required: GitHub PAT ===
# Classic PAT scope: `repo` only (full control of private repos; covers
# clone, fork, push, PR for both public and private). Do NOT add `workflow`
# unless you specifically need it.
# - Public repos: any user with fork permission works.
# - Private repos: PAT user must have read access AND repo must allow forking.
GITHUB_TOKEN=ghp_...

# === Required: AI CLI selection + credentials ===
# Supported in v1: claude
AI_CLI=claude

# Claude Code adapter (required when AI_CLI=claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gemini CLI adapter (example only; not wired in v1 — see GeminiCliAdapter.example.ts)
# GEMINI_API_KEY=...

# === Optional / defaults ===

# Host path where the backend creates per-job workdirs. The same path is
# bind-mounted from the host into the backend container so the path resolves
# identically on both sides — when the backend asks the host docker daemon to
# mount a workdir into a sandbox container, the path must mean the same thing
# everywhere.
HOST_JOB_WORKDIR_ROOT=/tmp/coverage-improver-jobs

# Coverage threshold below which files are flagged "low coverage" by default
# in the dashboard. Per-request override is supported via UI slider / API query.
DEFAULT_COVERAGE_THRESHOLD=80

# === Concurrency & backpressure ===
#
# Two distinct caps because the bottlenecks are different:
#   - sandbox capacity is HOST-bound (memory ~200-500MB per `npm install`,
#     disk for clones, dockerd throughput);
#   - AI capacity is ACCOUNT-bound (Anthropic rate limits / credit cost).
#
# A 16-core box can run 8 sandboxes happily but still cannot fan 8 jobs
# into Claude in parallel — the rate limit is on the API key, not the box.
# Defaults are conservative for a laptop running the demo.
MAX_CONCURRENT_SANDBOXES=4
MAX_CONCURRENT_AI_CALLS=2

# Admission control: max active (pending+running) jobs across the whole
# system. New requests beyond this return HTTP 503 (QUEUE_DEPTH_EXCEEDED).
# Prevents the in-memory queue from growing without bound under bursty
# fan-out (e.g. a "queue every low-coverage file" command across many
# repos at once). Set to 0 to disable.
MAX_QUEUE_DEPTH=50

# Event-loop stall threshold (milliseconds). When the worst-case stall in a
# 1s window exceeds this, the backend emits a warn log with mean/p99/max.
# Useful for catching unexpected CPU-bound work creeping in.
EVENT_LOOP_STALL_THRESHOLD_MS=50
