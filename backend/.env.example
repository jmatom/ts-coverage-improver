# Backend service
PORT=3000

# SQLite database file (relative to backend/, persisted via docker volume in compose)
DATABASE_PATH=./data/coverage.db

# AI CLI selection — must match a registered adapter in AiModule
# Supported in v1: claude
AI_CLI=claude

# === Adapter-specific credentials ===
# Each adapter declares its requiredEnv. The Nest module validates presence at boot.

# Claude Code adapter
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gemini CLI adapter (example only; not wired in v1)
# GEMINI_API_KEY=...

# === GitHub access ===
# PAT scopes required: repo, workflow
# Public repos: any user with fork permission works
# Private repos: PAT user must have read access AND repo must allow forking
GITHUB_TOKEN=ghp_...

# === Sandbox ===
# Image tag built from sandbox/Dockerfile via docker-compose
SANDBOX_IMAGE=coverage-improver-sandbox:latest

# Workdir on host where job containers mount cloned repos.
# When running backend in docker-compose, this must be a host path that the
# host docker socket can also see — typically a named volume root or /tmp.
JOB_WORKDIR_ROOT=/tmp/coverage-improver-jobs

# Coverage threshold below which files are flagged "low coverage" by default.
DEFAULT_COVERAGE_THRESHOLD=80

# === Concurrency & backpressure (see root .env.example for full rationale) ===
MAX_CONCURRENT_SANDBOXES=4
MAX_CONCURRENT_AI_CALLS=2
MAX_QUEUE_DEPTH=50
EVENT_LOOP_STALL_THRESHOLD_MS=50
