node_modules/
dist/
build/
# Anchored to package roots — an unanchored `coverage/` matches any
# directory named coverage at any depth, accidentally hiding real source
# under `src/.../coverage/`.
/coverage/
/backend/coverage/
/frontend/coverage/

# Local env (no secrets in git)
.env
.env.local

# Local dev artifacts
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
/tmp/

# OS
.DS_Store
*.log

# Per-developer Claude Code settings (model overrides, MCP servers, etc.).
# CLAUDE.md (shared project context) is tracked; this directory is not.
.claude/

# Editor / TS / Vite build artifacts that should never be committed
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
