node_modules/
dist/
build/
# Anchored to package roots — an unanchored `coverage/` matches any
# directory named coverage at any depth, accidentally hiding real source
# under `src/.../coverage/`.
/coverage/
/backend/coverage/
/frontend/coverage/

# Local env (no secrets in git)
.env
.env.local

# Local dev artifacts
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
/tmp/

# OS
.DS_Store
*.log

# Agent / local-machine context: contains absolute paths + workflow notes
# specific to one developer's environment, not useful to readers.
CLAUDE.md

# Editor / TS / Vite build artifacts that should never be committed
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
